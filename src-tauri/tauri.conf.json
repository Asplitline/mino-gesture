{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mino-gesture",
  "version": "0.1.0",
  "identifier": "com.mino.gesture",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "mino-gesture",
        "width": 840,
        "height": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
